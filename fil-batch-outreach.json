    {
      "parameters": {},
      "id": "b1000001-0001-0001-0001-000000000001",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        -240,
        320
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT mt.id as thread_id, c.id as contact_id, c.full_name,\n       cp.phone_number, p.id as property_id, p.address, p.city, p.state,\n       p.property_type, l.list_price, l.listed_cap_rate,\n       mt.thread_type\nFROM app.message_threads mt\nJOIN app.contacts c ON c.id = mt.contact_id\nJOIN app.contact_phones cp ON cp.contact_id = c.id AND cp.is_primary = TRUE\nLEFT JOIN app.properties p ON p.id = mt.property_id\nLEFT JOIN app.listings l ON l.property_id = p.id\nWHERE mt.status = 'active'\n  AND mt.stage = 'open'\n  AND mt.touchpoint_count = 0\n  AND cp.phone_number IS NOT NULL\n  AND cp.phone_number != ''\nORDER BY mt.created_at ASC\nLIMIT 50",
        "options": {}
      },
      "id": "2f50bd70-e98e-4a7d-93b5-d46db8b4b2f0",
      "name": "DB: Get Pending Outreach",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        224,
        1456
      ],
      "credentials": {
        "postgres": {
          "id": "REPLACE_WITH_SUPABASE_CREDENTIAL_ID",
          "name": "Supabase account"
        }
      },
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const d = item.json;\n  \n  // Skip if no data returned (empty query result)\n  if (!d.thread_id || !d.phone_number) continue;\n  \n  const firstName = (d.full_name || '').split(' ')[0] || 'there';\n  const address = d.address || '';\n  const city = d.city || '';\n  const state = d.state || '';\n  const location = city && state ? `${city}, ${state}` : city || state || '';\n\n  let message = '';\n  if (address && location) {\n    message = `Hey ${firstName}, this is Fil from Kumo Capital. I came across ${address} in ${location} and it caught my eye. Is it still available?`;\n  } else if (address) {\n    message = `Hey ${firstName}, this is Fil from Kumo Capital. I came across ${address} and it caught my eye. Is it still available?`;\n  } else {\n    message = `Hey ${firstName}, this is Fil from Kumo Capital. I saw one of your listings come across my desk and wanted to reach out. Got a minute?`;\n  }\n\n  results.push({\n    json: {\n      ...d,\n      message,\n      first_name: firstName\n    }\n  });\n}\n\nif (results.length === 0) {\n  return [{ json: { no_pending: true, message: 'No pending outreach found' } }];\n}\n\nreturn results;"
      },
      "id": "e821d167-bdb8-4e55-aef6-9c0841e7bbb0",
      "name": "Prepare Batch Messages",

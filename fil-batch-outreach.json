        "query": "-- Log outbound message\nINSERT INTO app.messages (thread_id, direction, sender, body, sent_at)\nVALUES ($1::uuid, 'outbound'::message_direction, 'bot'::message_sender, $2, NOW());\n\n-- Update thread\nUPDATE app.message_threads\nSET touchpoint_count = touchpoint_count + 1,\n    stage = 'open',\n    last_outreach_at = NOW(),\n    next_followup_at = NOW() + INTERVAL '24 hours',\n    updated_at = NOW()\nWHERE id = $1::uuid;",
